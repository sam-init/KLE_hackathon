# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8001
CORS_ORIGINS=http://localhost:3000

KEEP_WORKSPACES=false

# GitHub — Token 1: PR Review App
# Fine-grained PAT scoped to the PR repo
# Permissions: Pull requests (Read & Write), Issues (Read & Write)
GITHUB_REVIEW_TOKEN=

# GitHub — Token 2: Docs Push App
# Fine-grained PAT scoped to the docs/target repo
# Permissions: Contents (Read & Write)
GITHUB_DOCS_TOKEN=

# GitHub Webhook (optional — leave blank to skip signature validation)
GITHUB_WEBHOOK_SECRET=

# NVIDIA NIM
NIM_API_KEY=
NIM_BASE_URL=https://integrate.api.nvidia.com
NIM_MODEL_NEOTRON=nvidia/llama-3.1-nemotron-70b-instruct
NIM_MODEL_QWEN_DOCS=qwen/qwen2.5-coder-32b-instruct
NIM_MODEL_QWEN_REVIEW=qwen/qwen2.5-coder-32b-instruct
